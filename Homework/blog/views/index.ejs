<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8">
  <title>我的網誌</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <h1><a href="/">我的網誌</a></h1>
    <a href="/posts/new" class="btn">寫新文章</a>
    <% if (posts.length === 0) { %>
      <p class="empty">尚無文章</p>
    <% } %>
    <% posts.forEach(post => { %>
      <article>
        <h2><a href="/posts/<%= post.id %>"><%= post.title %></a></h2>
        <time><%= post.created_at %></time>
      </article>
    <% }) %>
  </div>
</body>
</html>
